generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Estimate {
  id             String   @id @default(cuid())
  projectName    String   @default("Jauns projekts")
  clientName     String?
  clientCompany  String?
  clientPhone    String?
  clientEmail    String?
  companyName    String?
  companyRegNr   String?
  offerValidDays Int      @default(30)
  advancePercent Float?
  notes          String?
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs Job[]
}

model Job {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name        String   @default("Jauns darbs")
  description String?
  quantity    Int      @default(1)
  sortOrder   Int      @default(0)
  jobType     String   @default("full")

  productionDiscount Float @default(0)
  deliveryDiscount   Float @default(0)

  materials MaterialItem[]
  costLines CostLine[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([estimateId])
}

model MaterialItem {
  id        String @id @default(cuid())
  jobId     String
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(0)

  name     String  @default("")
  notes    String?
  partType String  @default("flat")

  width    Float?
  length   Float?
  sideB    Float?
  thickness Float?
  outerDiam Float?

  pcsPerUnit Float @default(1)

  materialKey  String @default("steel")
  unit         String @default("m2")
  pricePerUnit Float  @default(0)
  wasteMarkup  Float  @default(0.10)

  weldingLength  Float @default(0)
  weldingHours   Float @default(0)
  grindingHours  Float @default(0)
  strainingHours Float @default(0)
  rollingHours   Float @default(0)
  drillingHours  Float @default(0)

  @@index([jobId])
}

model CostLine {
  id        String @id @default(cuid())
  jobId     String
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(0)

  section      String
  category     String
  lineKey      String
  label        String

  quantity     Float   @default(0)
  rate         Float   @default(0)
  unit         String  @default("st")

  autoLinked   Boolean @default(false)
  isCorrection Boolean @default(false)

  @@index([jobId])
}

model MetalDensity {
  id      String @id @default(cuid())
  name    String @unique
  nameLv  String
  density Float
}

model DefaultRate {
  id      String @id @default(cuid())
  lineKey String @unique
  label   String
  rate    Float
  unit    String
}
